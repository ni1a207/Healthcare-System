@startuml
skinparam Shadowing true
skinparam RoundCorner 5
skinparam MaxMessageSize 250

boundary "API Consumer" as AC #FEF9E7

box "auth-service" #5D6D7E
    participant "DispatcherServlet" as DS #White
    participant "Jackson" as Jackson #White
    participant "AuthController" as Ctrl #White
    participant "AuthService" as Service #White
    participant "UserService" as USrv #White
    participant "UserRepository" as Repo #White
    participant "BCryptPasswordEncoder" as BCrypt #White
    participant "JwtUtil" as Jwt #White
end box

database "auth_db" as DB #LightBlue

group #LightCyan Процесс аутентификации\nВнешний URL: POST {gateway-host}/auth/login → Внутренний URL: POST auth-service:4005/login

    AC -> DS ++: **[1]** POST /login (JSON)
    DS -> Jackson ++: **[2]** Десериализация (JSON -> DTO)
    Jackson --> DS --: **[3]** LoginRequestDTO

    note over DS, Ctrl #FFF3CD: **Важно**: @Valid отсутствует в AuthController —\nвалидация полей LoginRequestDTO не выполняется.\nНекорректные или пустые значения передаются без проверки.

    DS -> Ctrl ++: **[4]** login(loginRequestDTO)
    Ctrl -> Service ++: **[5]** authenticate(loginRequestDTO)
    Service -> USrv ++: **[6]** findByEmail(email)
    USrv -> Repo ++: findByEmail(email)
    Repo -> DB ++: SELECT * FROM users WHERE email = ?
    DB --> Repo --: ResultSet

    alt #MistyRose Пользователь не найден
        Repo --[#red]> USrv: Optional.empty()
        USrv --[#red]> Service: Optional.empty()
        Service --[#red]> Ctrl: Optional.empty()
        Ctrl --[#red]> DS: <color:#red>401 UNAUTHORIZED</color>
        DS --[#red]> AC: <color:#red>401 UNAUTHORIZED</color>
    end

    Repo --> USrv --: Optional<User>
    USrv --> Service --: Optional<User>

    Service -> BCrypt ++: **[7]** matches(rawPassword, hashedPassword)

    alt #MistyRose password == null
         BCrypt --[#red]> Service: <color:#red>IllegalArgumentException (password is null)</color>
                Service --[#red]> Ctrl: <color:#red>IllegalArgumentException</color>
                Ctrl --[#red]> DS: <color:#red>IllegalArgumentException</color>
                DS --[#red]> AC: <color:#red>500 INTERNAL SERVER ERROR</color>
    end

    alt #MistyRose Пароль не совпал
        BCrypt --[#red]> Service: false
        Service --[#red]> Ctrl: Optional.empty()
        Ctrl --[#red]> DS: <color:#red>401 UNAUTHORIZED</color>
        DS --[#red]> AC: <color:#red>401 UNAUTHORIZED</color>
    end

    BCrypt --[#green]> Service --: true

    Service -> Jwt ++: **[8]** generateToken(email, role)
    note right of Jwt: Payload: sub=email, role=role\niat=now, exp=now+10h\nsignWith(secretKey) → HS256
    Jwt --[#green]> Service --: JWT String

    Service --[#green]> Ctrl --: **[9]** Optional<String> (token)

    Ctrl -> Ctrl: **[10]** new LoginResponseDTO(token)
    Ctrl --> DS: LoginResponseDTO

    DS -> Jackson ++: **[11]** Сериализация (DTO -> JSON)
    Jackson --> DS --: JSON

    DS --[#green]> AC --: **[12]** 200 OK (JSON)
    deactivate Ctrl
    deactivate USrv
    deactivate Repo
    deactivate BCrypt

end

group #WhiteSmoke Системные сбои
    note over DS, DB #FFE4E1: Критический сбой — необработанное исключение\n(недоступность БД, ошибка конфигурации секретного ключа)\n→ 500 INTERNAL SERVER ERROR
end

@enduml
