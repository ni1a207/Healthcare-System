@startuml
skinparam Shadowing true
skinparam RoundCorner 5
skinparam MaxMessageSize 250
participant "frontend" as FE #FFF2CC
boundary "api-gateway" as GW #FEF9E7
participant "auth-service" as Auth #EBF5FB
participant "patient-service" as PS #F4ECF7
database "patient-db" as DB #F4ECF7
autonumber "<b>[0]</b>"
group #LightCyan Просмотр зарегистрированных пациентов
    FE -> GW: GET api/patients\n(Authorization: Bearer <token>)
    activate FE #White
    activate GW
    GW -> GW: Проверка токена
    autonumber stop
    GW -> Auth: GET /validate\n(Authorization: Bearer <token>)
    activate Auth
    autonumber stop
    Auth --[#green]> GW: 200 OK
    deactivate Auth
autonumber resume
    GW -> PS: GET /patients
    activate PS
PS->DB: Поиск записей
  activate DB
  autonumber stop
DB-->PS: Все записи
deactivate DB
autonumber resume
PS--[#green]>GW: 200 OK (JSON)
deactivate PS
GW--[#green]>FE: 200 OK (JSON)
deactivate GW
  end
@enduml