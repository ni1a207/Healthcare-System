@startuml
skinparam Shadowing true
skinparam RoundCorner 5
skinparam MaxMessageSize 250
participant "frontend" as FE #FFF2CC
boundary "api-gateway" as GW #FEF9E7
participant "auth-service" as Auth #EBF5FB
participant "patient-service" as PS #F4ECF7
database "patient-db" as DB #F4ECF7
participant "BillingServiceGrpcClient" as BSGRPC #F4ECF7
participant "billing-service" as BS #F4ECF7
participant "kafka" as K #F4ECF7
autonumber "<b>[0]</b>"
group #LightCyan Регистрация нового пациента
    FE -> GW: POST /api/patients\n(Authorization: Bearer <token>, JSON body)
    activate GW
        GW -> GW: Проверка токена
            autonumber stop
    GW -> Auth: GET /validate\n(Authorization: Bearer <token>)
    activate Auth
    autonumber stop
    Auth --[#green]> GW: 200 OK
    deactivate Auth
autonumber resume
    GW -> PS: POST /patients \n(JSON body)
    activate PS
  PS->PS: Валидация входных параметров
  PS->DB: Поиск записей по полю email
  activate DB
  autonumber stop
    DB-->PS: Записи не найдены
PS->DB: Новая запись + генерация UUID
DB-->PS: Данные записаны
deactivate DB
autonumber resume
PS->BSGRPC: BillingRequest
activate BSGRPC
BSGRPC->BS: CreateBillingAccount
activate BS
BS->BS: Логирование входящих данных
autonumber stop
BS--[#green]>BSGRPC: BillingResponse
deactivate BS
BSGRPC--[#green]>PS: BillingResponse
deactivate BSGRPC
autonumber resume
PS->PS: Создает PatientEvent
PS->>K: PatientEvent
PS--[#green]>GW: 200 OK (JSON)
deactivate PS
GW--[#green]>FE: 200 OK (JSON)
deactivate GW
  end
@enduml