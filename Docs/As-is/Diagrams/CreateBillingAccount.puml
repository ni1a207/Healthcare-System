@startuml
skinparam Shadowing true
skinparam RoundCorner 5
skinparam MaxMessageSize 250

box "patient-service" #5D6D7E
    participant "BillingServiceGrpcClient" as Client #White
end box

box "billing-service" #4A235A
    participant "grpc-netty-shaded" as Netty #White
    participant "protobuf-java" as Proto #White
    participant "BillingGrpcService\n(@GrpcService)" as Grpc #White
end box

group #LightCyan Процесс создания биллинг-аккаунта\nUnary gRPC: billing.BillingService/CreateBillingAccount\npatient-service → billing-service:9001 (plaintext)

    Client -> Client: **[1]** BillingRequest.newBuilder()\n.setPatientId(patientId)\n.setName(name)\n.setEmail(email)\n.build()

    alt #MistyRose billing-service недоступен
        Client --[#red]> Client: <color:#red>StatusRuntimeException (14 UNAVAILABLE)</color>
    end

    Client -> Netty ++: **[2]** HTTP/2 TCP-пакет\n(BillingRequest, Protobuf binary)

    Netty -> Proto ++: **[3]** Десериализация\n(binary → BillingRequest)

    alt #MistyRose Повреждённая структура данных
        Proto --[#red]> Client: <color:#red>13 INTERNAL</color>
        deactivate Proto
    end

    Proto --> Netty --: BillingRequest

    Netty -> Grpc ++: **[4]** createBillingAccount\n(billingRequest, responseObserver)
    note right of Grpc: log.info("createBillingAccount\nrequest received {}", billingRequest)

    Grpc -> Grpc: **[5]** BillingResponse.newBuilder()\n.setAccountId("12345")\n.setStatus("ACTIVE")\n.build()
    note right of Grpc: Mock — сохранение в БД\nи генерация accountId\nне выполняются.

    Grpc -> Proto ++: **[6]** responseObserver.onNext(response)\n(BillingResponse → binary)
    Proto --> Grpc --: serialized

    Grpc -> Netty: **[7]** responseObserver.onCompleted()
    deactivate Grpc

    Netty --[#green]> Client --: **[8]** 0 OK\nBillingResponse\n{accountId: "12345", status: "ACTIVE"}

    note right of Client: log.info("Received response from\nbilling service via GRPC: {}", response)

end
@enduml
